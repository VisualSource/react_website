    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-router-dom": "^5.2.0",
    "shineout": "^1.6.2"
  },
  "scripts": {
    "start": "rescripts start",
    "prestart": "npm run build-css",
    "build": "rescripts build",
    "test": "rescripts test",
    "build-css": "node-sass-chokidar src/ -o src/ --recursive",
    "watch-css": "npm run build-css && node-sass-chokidar src/styles/sass -o src/styles/css --watch",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/materialize-css": "^1.0.8",
    "@types/react-router-dom": "^5.1.6",
    "node-sass-chokidar": "^1.5.0",
    "@rescripts/cli": "0.0.15",
    "@rescripts/rescript-use-babel-config": "0.0.10",
    "@rescripts/rescript-use-rewire": "0.0.6",
    "@testing-library/jest-dom": "^5.11.6",
    "@testing-library/react": "^11.2.2",
    "@testing-library/user-event": "^12.6.0",
    "@types/jest": "^26.0.19",
    "@types/node": "^12.19.11",
    "@types/react": "^16.14.2",
    "@types/react-dom": "^16.9.10",
    "babel-plugin-import": "^1.13.3",
    "web-vitals": "^0.2.4",
    "react-scripts": "4.0.1",
    "typescript": "^4.1.3"
  }
