{
  "name": "website2",
  "version": "1.6.0",
  "private": true,
  "scripts": {
    "start": "rescripts start",
    "prestart": "npm run build-css",
    "build": "rescripts build",
    "test": "rescripts test",
    "build-css": "node-sass-chokidar src/ -o src/ --recursive",
    "watch-css": "npm run build-css && node-sass-chokidar src/styles/sass -o src/styles/css --watch",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version",
      "last 1 ChromeAndroid version",
      "last 1 FirefoxAndroid version",
      "last 1 iOS version"
    ]
  },
  "dependencies": {
    "@auth0/auth0-react": "^1.4.0",
    "github-api": "^3.4.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-html-parser": "^2.0.2",
    "react-router-dom": "^5.2.0",
    "shineout": "^1.6.2"
  },
  "devDependencies": {
    "@rescripts/cli": "^0.0.16",
    "@rescripts/rescript-use-babel-config": "^0.0.12",
    "@rescripts/rescript-use-rewire": "^0.0.6",
    "@testing-library/jest-dom": "^5.11.10",
    "@testing-library/react": "^11.2.6",
    "@testing-library/user-event": "^13.1.1",
    "@types/jest": "^26.0.22",
    "@types/node": "^14.14.37",
    "@types/react": "^17.0.3",
    "@types/react-dom": "^17.0.3",
    "@types/react-html-parser": "^2.0.1",
    "@types/react-router-dom": "^5.1.7",
    "babel-plugin-import": "^1.13.3",
    "node-sass-chokidar": "^1.5.0",
    "react-app-rewire-less": "^2.1.3",
    "react-scripts": "^4.0.3",
    "typescript": "^4.2.3",
    "web-vitals": "^1.1.1"
  }
}
