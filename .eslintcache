[{"C:\\webprojects\\website2\\src\\index.tsx":"1","C:\\webprojects\\website2\\src\\App.tsx":"2","C:\\webprojects\\website2\\src\\pages\\home.tsx":"3","C:\\webprojects\\website2\\src\\pages\\profile.tsx":"4","C:\\webprojects\\website2\\src\\routes\\PrivateRoute.tsx":"5","C:\\webprojects\\website2\\src\\pages\\Login.tsx":"6","C:\\webprojects\\website2\\src\\pages\\Server.tsx":"7","C:\\webprojects\\website2\\src\\pages\\Projects.tsx":"8","C:\\webprojects\\website2\\src\\pages\\Project.tsx":"9","C:\\webprojects\\website2\\src\\access\\github.ts":"10","C:\\webprojects\\website2\\src\\pages\\ViewProfile.tsx":"11","C:\\webprojects\\website2\\src\\access\\check_content.ts":"12"},{"size":850,"mtime":1609431514179,"results":"13","hashOfConfig":"14"},{"size":6295,"mtime":1609449487706,"results":"15","hashOfConfig":"14"},{"size":440,"mtime":1609395361784,"results":"16","hashOfConfig":"14"},{"size":10664,"mtime":1609448253411,"results":"17","hashOfConfig":"14"},{"size":758,"mtime":1609267816984,"results":"18","hashOfConfig":"14"},{"size":893,"mtime":1609392893647,"results":"19","hashOfConfig":"14"},{"size":7238,"mtime":1609398852537,"results":"20","hashOfConfig":"14"},{"size":2434,"mtime":1609433526322,"results":"21","hashOfConfig":"14"},{"size":2534,"mtime":1609433859834,"results":"22","hashOfConfig":"14"},{"size":397,"mtime":1609286481818,"results":"23","hashOfConfig":"14"},{"size":1378,"mtime":1609433845888,"results":"24","hashOfConfig":"14"},{"size":1146,"mtime":1609449330925,"results":"25","hashOfConfig":"14"},{"filePath":"26","messages":"27","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"28"},"zsy9q4",{"filePath":"29","messages":"30","errorCount":0,"warningCount":8,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"31","messages":"32","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"28"},{"filePath":"33","messages":"34","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"35","usedDeprecatedRules":"28"},{"filePath":"36","messages":"37","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"28"},{"filePath":"38","messages":"39","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"28"},{"filePath":"40","messages":"41","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"42","usedDeprecatedRules":"28"},{"filePath":"43","messages":"44","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"45","usedDeprecatedRules":"28"},{"filePath":"46","messages":"47","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"48","usedDeprecatedRules":"28"},{"filePath":"49","messages":"50","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"51"},{"filePath":"52","messages":"53","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"28"},{"filePath":"54","messages":"55","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},"C:\\webprojects\\website2\\src\\index.tsx",[],["56","57"],"C:\\webprojects\\website2\\src\\App.tsx",["58","59","60","61","62","63","64","65"],"C:\\webprojects\\website2\\src\\pages\\home.tsx",[],"C:\\webprojects\\website2\\src\\pages\\profile.tsx",["66"],"import React, { useEffect, useState } from \"react\";\r\nimport { useAuth0 } from \"@auth0/auth0-react\";\r\nimport {Button,Spin, Image, Modal, Form, Input, Message, Radio} from 'shineout';\r\nimport {Redirect} from 'react-router-dom';\r\nimport CONFIG from '../config.json';\r\n\r\n/*const CodeRules = {\r\n  code: [\r\n    { required: true, message: 'Please enter code.' },\r\n    { min: 25, message: 'Code must be at least {min} characters.' },\r\n    { regExp: /[a-z]+/i, message: 'Password at least has one letter.' },\r\n  ]\r\n}*/\r\n\r\nconst Profile = () => {\r\n  const { user, isAuthenticated, getAccessTokenSilently} = useAuth0();\r\n  const [userMetadata, setUserMetadata] = useState<any>(null);\r\n  const [loading, setLoading] = useState(true);\r\n  const [showEdit,setShowEdit] = useState(false);\r\n  //const [showCode,setShowCode] = useState(false);\r\n  const [showCred,setShowCred] = useState(false);\r\n  const [update,setUpdate] = useState(true);\r\n\r\n  const credClose = () => {\r\n    setShowCred(false);\r\n  }\r\n  const renderCredFooter = () =>{\r\n    return <div>\r\n              <Button onClick={credClose}>Cancel</Button>\r\n              {\r\n                //@ts-ignore\r\n                <Modal.Submit>Submit</Modal.Submit>\r\n              }\r\n           </div>\r\n  }\r\n  const submitCred = async (data: any) => {\r\n    Message.info(<div>This Feture has not been implemted  yet</div>, 20, {\r\n      position: \"top-right\",\r\n      title: \"Customization\",\r\n    });\r\n    credClose();\r\n  }\r\n\r\n\r\n  const editClose = () => {\r\n    setShowEdit(false);\r\n  }\r\n  const renderEditFooter = () =>{\r\n    return <div>\r\n              <Button onClick={editClose}>Cancel</Button>\r\n              {\r\n                //@ts-ignore\r\n                <Modal.Submit>Submit</Modal.Submit>\r\n              }\r\n           </div>\r\n  }\r\n  const submitEdit = async (data: any) => {\r\n    Message.info(<div>Your changes have been submited</div>, 20, {\r\n      position: \"top-right\",\r\n      title: \"Request Submited\",\r\n    });\r\n    editClose();\r\n    try {\r\n      \r\n      const accessToken = await getAccessTokenSilently({\r\n        audience: CONFIG.auth.audience,\r\n        scope: \"update:connection update:users update:current_user update:users_app_metadata\",\r\n      });\r\n\r\n      const request_update = await fetch(`${CONFIG.auth.audience}users/${user.sub}`,{\r\n        method: \"PATCH\",\r\n        body: JSON.stringify({user_metadata: {color: data.color}}),\r\n        headers: {\r\n          \"content-type\": \"application/json\",\r\n          Authorization: `Bearer ${accessToken}`,\r\n        }\r\n      });\r\n\r\n      const request = await request_update.json();\r\n      if (request?.statusCode) {\r\n        Message.error(<div>{request.error}</div>, 20, {\r\n          position: \"top-right\",\r\n          title: \"Error in Request\",\r\n        });\r\n      }else{\r\n        window.sessionStorage.setItem(\"metadata\",JSON.stringify({user_metadata: request.user_metadata, app_metadata: request.app_metadata}));\r\n        setUserMetadata({user_metadata: request.user_metadata, app_metadata: request.app_metadata});\r\n        Message.success(<div>Updated Profile</div>, 20, {\r\n          position: \"top-right\",\r\n          title: \"Updated\",\r\n        });\r\n      }\r\n      \r\n      \r\n    } catch (error) {\r\n      Message.error(<div>{error.message}</div>, 20, {\r\n        position: \"top-right\",\r\n        title: \"Error in Request\",\r\n      });\r\n    }\r\n  }\r\n\r\n/*\r\n  const codeClose = () => {\r\n    setShowCode(false);\r\n  }\r\n  const handleCodeSubmit = async (data: any) => {\r\n    codeClose();\r\n    Message.info(<div>Your code has been submited.</div>, 20, {\r\n      position: \"top-right\",\r\n      title: \"Request Submited\",\r\n    });\r\n    try {\r\n      const accessToken = await getAccessTokenSilently({\r\n        audience: CONFIG.auth.audience,\r\n        scope: \"update:users update:users_app_metadata update:current_user_metadata\",\r\n      });\r\n      const request = await fetch(`${CONFIG.scipts}register_code.php`,{\r\n        method:\"POST\",\r\n        body: JSON.stringify({ code: data.code, sub: user.sub, token: accessToken })\r\n      });\r\n      const response = await request.json();\r\n      console.log(response);\r\n      \r\n      if (response.code === 200) {\r\n        Message.success(<div>Your code has been registered</div>, 20, {\r\n          position: \"top-right\",\r\n          title: \"Register success\",\r\n        });\r\n      }else{\r\n        throw new Error(\"Failed to register code.\");\r\n      }\r\n    } catch (error) {\r\n      Message.error(<div>There was an error</div>, 20, {\r\n        position: \"top-right\",\r\n        title: \"Request\",\r\n      });\r\n    }\r\n\r\n  }\r\n  const renderCodeFooter = () =>{\r\n    return <div>\r\n              <Button onClick={codeClose}>Cancel</Button>\r\n              {\r\n                //@ts-ignore\r\n                <Modal.Submit>Submit</Modal.Submit>\r\n              }\r\n           </div>\r\n  }\r\n*/\r\n  useEffect(()=>{\r\n    const getUserMetadata = async () => {\r\n        let raw = window.sessionStorage.getItem(\"metadata\");\r\n        if (raw != null) {\r\n          setUserMetadata(JSON.parse(raw));\r\n          setLoading(false);\r\n        }else{\r\n            try {\r\n                const accessToken = await getAccessTokenSilently({\r\n                  audience: CONFIG.auth.audience,\r\n                  scope: \"read:current_user read:users_app_metadata read:user_metadata\",\r\n                });\r\n          \r\n                const userDetailsByIdUrl = `${CONFIG.auth.audience}users/${user.sub}`;\r\n          \r\n                const metadataResponse = await fetch(userDetailsByIdUrl, {\r\n                  headers: {\r\n                    Authorization: `Bearer ${accessToken}`,\r\n                  },\r\n                });\r\n                const all = await metadataResponse.json();\r\n                window.sessionStorage.setItem(\"metadata\",JSON.stringify({app_metadata: all.app_metadata, user_metadata: all.user_metadata} as any));\r\n                setUserMetadata(all);\r\n                setLoading(false);\r\n                setUpdate(false);\r\n              } catch (e) {\r\n                setLoading(false);\r\n                console.log(e.message);\r\n              }\r\n        }\r\n      };\r\n      getUserMetadata();\r\n},[update]);\r\n  \r\n  if (!loading){\r\n    if (isAuthenticated){\r\n      return <div id=\"user-profile\">\r\n                  <Modal className=\"modal-sizing\" footer={renderEditFooter()} title=\"Edit Profile\" visible={showEdit} onClose={editClose}>\r\n                    <Form onSubmit={submitEdit}>\r\n                      <Form.Item label=\"Name\">\r\n                          <Input name=\"name\" defaultValue={user.name}/>\r\n                      </Form.Item>\r\n                      <Form.Item label=\"Nickname\">\r\n                          <Input name=\"nickname\" defaultValue={user.nickname}/>\r\n                      </Form.Item>\r\n                      <Form.Item label=\"Email\">\r\n                          <Input name=\"email\" type=\"email\" defaultValue={user.email}/>\r\n                      </Form.Item>\r\n                      <Form.Item label=\"Image Url\">\r\n                          <Input name=\"picture\" type=\"url\" defaultValue={user.picture}/>\r\n                      </Form.Item>\r\n                      <Form.Item label=\"Favorite Colors\" tip=\"select a color\">\r\n                        <Radio.Group\r\n                          name=\"color\"\r\n                          keygen={(d: any) => d}\r\n                          data={['red', 'orange', 'yellow', 'green', 'cyan', 'blue', 'violet','darkblue']}\r\n                          defaultValue={userMetadata.user_metadata.color}\r\n                        />\r\n                      </Form.Item>\r\n                    </Form>\r\n                  </Modal>\r\n                  {\r\n                    /**\r\n                     *  <Modal className=\"modal-sizing\" footer={renderCodeFooter()} title=\"Enter Code\" visible={showCode} onClose={codeClose}>\r\n                          <Form labelWidth={100} rules={CodeRules} labelAlign=\"right\"  style={{ maxWidth: 400 }} onSubmit={handleCodeSubmit}>\r\n                            <Form.Item required label=\"Code\">\r\n                                <Input name=\"code\" placeholder=\"enter a code\" type=\"password\"/>\r\n                            </Form.Item>\r\n                          </Form>\r\n                        </Modal>\r\n                     */\r\n                  }\r\n                  <Modal className=\"modal-sizing\" footer={renderCredFooter()} title=\"Edit credentials\" visible={showCred} onClose={credClose}>\r\n                    <Form labelWidth={100} labelAlign=\"right\"  style={{ maxWidth: 400 }} onSubmit={submitCred}>\r\n                       <Form.Item required label=\"New password\">\r\n                          <Input name=\"password\" placeholder=\"enter new password\" type=\"password\"/>\r\n                       </Form.Item>\r\n                       <Form.Item required label=\"Reenter password\">\r\n                          <Input name=\"check_password\" placeholder=\"reenter password\" type=\"password\"/>\r\n                       </Form.Item>\r\n                    </Form>\r\n                  </Modal>\r\n                  <div id=\"info\">\r\n                      <h1>{user.name}</h1>\r\n                      <hr/>\r\n                      <p>{user.email}</p>\r\n                      <div>\r\n                        <p>Color: <span style={{color: userMetadata?.user_metadata?.color ?? \"blue\"}}>{userMetadata?.user_metadata?.color ?? \"blue\"}</span></p>\r\n                        <Button.Group size=\"small\" type=\"primary\">\r\n                            <Button onClick={()=>{setShowEdit(true)}}> \r\n                              <span style={{fontSize: \"15px\"}} className=\"material-icons\">create</span>\r\n                              Edit\r\n                            </Button>\r\n                           {\r\n                             // <Button onClick={()=>{setShowCode(true)}}><span style={{fontSize: \"15px\"}} className=\"material-icons\">build</span>Enter Code</Button>\r\n                           }\r\n                            <Button onClick={()=>{setShowCred(true)}}>\r\n                              <span style={{fontSize: \"15px\"}} className=\"material-icons\">vpn_key</span>\r\n                              Credentials\r\n                            </Button>\r\n                        </Button.Group>\r\n                      </div>\r\n                  </div>\r\n                  <div>\r\n                      <Image src={user.picture} shape=\"circle\" width={250} height={250}/>\r\n                      <hr/>\r\n                      <code>{user.sub}</code>\r\n                  </div>\r\n            </div>\r\n    }else{\r\n      return <Redirect to=\"/login\"/>\r\n    }\r\n  }else{\r\n    return <div className=\"loader\">\r\n              <Spin size=\"54px\" name=\"cube-grid\" color=\"#ff3e00\" />\r\n          </div>\r\n  }\r\n};\r\n\r\nexport default Profile;","C:\\webprojects\\website2\\src\\routes\\PrivateRoute.tsx",[],"C:\\webprojects\\website2\\src\\pages\\Login.tsx",[],"C:\\webprojects\\website2\\src\\pages\\Server.tsx",["67"],"import React, {useState,useEffect} from 'react';\r\nimport { useAuth0 } from \"@auth0/auth0-react\";\r\nimport {Redirect} from 'react-router-dom';\r\nimport { Spin, Button, CardGroup, Message } from 'shineout';\r\nimport {Link} from 'react-router-dom';\r\nimport CONFIG from '../config.json';\r\n\r\n\r\n\r\ninterface PlayerListData{\r\n   id: string;\r\n   name: string;\r\n   has_account: boolean;\r\n}\r\ninterface ServerData {\r\n  online: boolean;\r\n  host: string;\r\n  players: PlayerListData[];\r\n  player_count: number;\r\n  max_players: number;\r\n}\r\n\r\nenum ButtonText{\r\n  START = \"Start\",\r\n  STARTING = \"Starting\",\r\n  STOP = \"Stop\",\r\n  STOPING = \"STOPING\",\r\n  WATING = \"Wating..\"\r\n}\r\nenum ButtonColor {\r\n  GOOD = \"success\",\r\n  BAD = \"danger\",\r\n  WARN = \"warning\"\r\n}\r\n\r\n\r\nfunction PlayerItem(data: any){\r\n    return (\r\n      <div className=\"player\">\r\n        <span className=\"material-icons\">account_circle</span> \r\n        <code><Link to={`/user-account/${data.name}`}>{data.name}</Link></code>\r\n      </div>\r\n    )\r\n}\r\n\r\nexport default function Server(){\r\n    const { user, isAuthenticated, getAccessTokenSilently } = useAuth0();\r\n    const [userMetadata, setUserMetadata] = useState(null);\r\n    const [content_loading,setContentLoading] = useState(true);\r\n    const [status,setStatus] = useState({color: ButtonColor.WARN, loading: true, text: ButtonText.WATING});\r\n    const [server_info, setServerInfo] = useState<ServerData>({online: false, host: 'none', players: [], player_count: 0, max_players: 10});\r\n\r\n    const fetchServerData = async () => {\r\n        try {\r\n          const server_data = await (await fetch(`${CONFIG.scipts}server_info.php`)).json();\r\n          if (server_data.code === 200) {\r\n            setServerInfo({\r\n              online: true,\r\n              host: \"127.0.0.1\",\r\n              players: Array.isArray(server_data.players) ? server_data.players : [],\r\n              player_count: server_data?.player_count ? server_data?.player_count : 0,\r\n              max_players: server_data?.max_players ? server_data?.max_players : 10\r\n            });\r\n            setStatus({color: ButtonColor.BAD, loading: false, text: ButtonText.STOP});\r\n          }else{\r\n            setStatus({color: server_info.online ? ButtonColor.BAD : ButtonColor.GOOD, loading: false, text: server_info.online ? ButtonText.STOP : ButtonText.START});\r\n          }\r\n        } catch (error) {\r\n          console.error(error);  \r\n        }\r\n      setContentLoading(false);\r\n    }\r\n\r\n    const handle_button = async () => {\r\n        setStatus({color: ButtonColor.WARN, loading: true, text: ButtonText.WATING});\r\n        try {\r\n          const accessToken = await getAccessTokenSilently({\r\n            audience: CONFIG.auth.audience,\r\n            scope: \"read:current_user read:users_app_metadata\",\r\n          });\r\n\r\n          const request = await fetch(`${CONFIG.scipts}control.php`,{\r\n            method:\"POST\",\r\n            body: JSON.stringify({\r\n              token: accessToken,\r\n              request_type: server_info.online ? \"stop\" : \"start\",\r\n              sub: user.sub\r\n            })\r\n          });\r\n\r\n          const responce = await request.json();\r\n\r\n          if (responce.code === 200) {\r\n            Message.success(<div>The Request has been completed</div>, 20, {\r\n              position: \"top-right\",\r\n              title: \"Server\",\r\n            });\r\n            fetchServerData();\r\n          }else{\r\n            setStatus({color: server_info.online ? ButtonColor.BAD : ButtonColor.GOOD, loading: false, text: server_info.online ? ButtonText.STOP : ButtonText.START});\r\n            Message.error(<div>There was an error in the request</div>, 20, {\r\n              position: \"top-right\",\r\n              title: \"Server\",\r\n            });\r\n          }\r\n        } catch (error) {\r\n          setStatus({color: server_info.online ? ButtonColor.BAD : ButtonColor.GOOD, loading: false, text: server_info.online ? ButtonText.STOP : ButtonText.START});\r\n          Message.error(<div>There was an error in the request</div>, 20, {\r\n            position: \"top-right\",\r\n            title: \"Server\",\r\n          });\r\n        }\r\n    }\r\n\r\n\r\n    useEffect(()=>{\r\n      const getUserMetadata = async () => {\r\n          let raw = window.sessionStorage.getItem(\"metadata\");\r\n          if (raw != null) {\r\n            setUserMetadata(JSON.parse(raw));\r\n            fetchServerData();\r\n          }else{\r\n              try {\r\n                  const accessToken = await getAccessTokenSilently({\r\n                    audience: CONFIG.auth.audience,\r\n                    scope: \"read:current_user read:users_app_metadata read:user_metadata\",\r\n                  });\r\n            \r\n                  const userDetailsByIdUrl = `${CONFIG.auth.audience}users/${user.sub}`;\r\n            \r\n                  const metadataResponse = await fetch(userDetailsByIdUrl, {\r\n                    headers: {\r\n                      Authorization: `Bearer ${accessToken}`,\r\n                    },\r\n                  });\r\n                  const all = await metadataResponse.json();\r\n                  window.sessionStorage.setItem(\"metadata\",JSON.stringify({app_metadata: all.app_metadata, user_metadata: all.user_metadata} as any));\r\n                  setUserMetadata(all);\r\n                  fetchServerData();\r\n                } catch (e) {\r\n                  setContentLoading(false);\r\n                  console.log(e.message);\r\n                }\r\n          }\r\n        };\r\n        getUserMetadata();\r\n  },[]);\r\n\r\n    if (!content_loading) {\r\n        if (isAuthenticated && (userMetadata as any)?.app_metadata?.minecraft_auth) {\r\n            return (\r\n                <div id=\"minecraft-server\">\r\n                    <aside id=\"server-status\">\r\n                      <h3 className={`status ${server_info?.online ? \"online\" : \"offline\"}`}>Status:</h3>\r\n                      <span>Server Ip: <code>{server_info?.host ?? \"None\"}</code></span>\r\n                    </aside>\r\n                    <div id=\"controls\">\r\n                        <h1>Minecraft Server Dashboard</h1>\r\n                        <h4>Click to {server_info.online ? \"stop\" : \"start\"} Server</h4>\r\n                        <div>\r\n                          <Button onClick={()=>handle_button()} type={status.color} size=\"large\" loading={status.loading}>{status.text}</Button>\r\n                        </div>\r\n                    </div>\r\n                    <div id=\"player-list\">\r\n                      <h3>Players Online</h3>\r\n                      <hr/>\r\n                      <p>{server_info.player_count}/{server_info.max_players}</p>\r\n                      <div>\r\n                        <CardGroup columns={1} height={100}>\r\n                            {server_info?.players.map(v=>{\r\n                              //@ts-ignore\r\n                              return <CardGroup.Item key={v.id}>{PlayerItem(v)}</CardGroup.Item>\r\n                            })}\r\n                        </CardGroup>\r\n                      </div>\r\n                    </div>\r\n                </div>\r\n            );\r\n        }else {\r\n            return <Redirect to=\"/\"/>\r\n        }\r\n    }else{\r\n        return <div className=\"loader\">\r\n                <Spin size=\"54px\" name=\"cube-grid\" color=\"#ff3e00\" />\r\n            </div>\r\n    }\r\n\r\n}\r\n\r\n","C:\\webprojects\\website2\\src\\pages\\Projects.tsx",["68"],"import React, {useEffect,useState} from 'react';\r\nimport { Carousel, Spin} from 'shineout';\r\nimport {useHistory} from 'react-router-dom';\r\nimport CONFIG from '../config.json';\r\n\r\nexport default function Projects(){\r\n    const [loading, setLoading] = useState(true);\r\n    const [projects, setProjects] = useState();\r\n    const history = useHistory();\r\n\r\n    useEffect(()=>{\r\n        const loadContent = async () => {\r\n\r\n            let raw = window.localStorage.getItem(\"projects\");\r\n\r\n            let parse = [];\r\n\r\n            if (raw == null) {\r\n                try {\r\n                    const data =  await (await fetch(CONFIG.db)).json();\r\n                  \r\n                    window.localStorage.setItem(\"projects\",JSON.stringify(data));\r\n                    parse = data;\r\n                } catch (error) {\r\n                    console.error(error);\r\n                    setLoading(false);\r\n                }\r\n            }else{\r\n                let a = JSON.parse(raw);\r\n                parse = a;\r\n            }\r\n\r\n            setProjects(parse.map(({images, title, carousel_color, text_bg_color, repo, text_shadow}: any, index: number)=>{\r\n                return <div key={repo} className=\"carousel-card\" style={{ background: carousel_color ?? \"#292933\", backgroundImage: images[0] ? `url(${images[0]})` : \"none\", backgroundSize: \"100% 100%\"}}>\r\n                            <div onClick={()=>{history.push(`/projects/${repo}/${index}`);}} \r\n                                 style={{ background: text_bg_color ?? '#ff3e00'}} \r\n                                 className={`project-text${text_shadow ? \" project-bg-shadow\" : \"\"}`}>{title}</div>\r\n                        </div>\r\n            }));\r\n            setLoading(false);\r\n         \r\n        }\r\n        loadContent();\r\n    },[]);\r\n\r\n    if (!loading) {\r\n        return <Carousel interval={5000} animation=\"slide-y\" indicatorPosition=\"left\" indicatorType=\"line\">\r\n                    <div className=\"carousel-card\" style={{  backgroundImage: `url(${CONFIG.root}/content/projects.webp)` , backgroundSize: \"100% 100%\"}}>\r\n                            <div style={{ background: '#ff3e00'}} className={`project-text project-bg-shadow`}>Projects</div>\r\n                    </div>\r\n                    {projects}\r\n                </Carousel>\r\n    }\r\n\r\n    return <div className=\"loader\">\r\n            <Spin size=\"54px\" name=\"cube-grid\" color=\"#ff3e00\" />\r\n        </div>\r\n}\r\n\r\n","C:\\webprojects\\website2\\src\\pages\\Project.tsx",["69"],"import React, {useState, useEffect} from 'react';\r\nimport {useParams} from 'react-router-dom';\r\nimport {Spin} from 'shineout';\r\nimport CONFIG from '../config.json';\r\n\r\nimport {Markdown} from '../access/github';\r\nimport \"../style/markdown.css\"\r\n\r\n\r\nexport default function Project(){\r\n    const [isLoading, setIsLoading] = useState(true);\r\n    const [content,setContent] = useState<any>();\r\n    const [desc,setDesc] = useState<any>();\r\n    const {project, id} = useParams<{project: string, id: string}>();\r\n \r\n    const getStyle = () => {\r\n        if (desc) {\r\n            if (desc?.images[0]){\r\n                return {backgroundColor: \"orange\", backgroundImage: `url(${CONFIG.root}${desc.images[0]})` ,backgroundSize:\"100% 100%\"};\r\n            }else{\r\n                return {backgroundColor: desc?.carousel_color ?? \"orange\"}\r\n            }\r\n        }\r\n\r\n        \r\n        return {backgroundColor: \"orange\"}\r\n    }\r\n    useEffect(()=>{\r\n      \r\n        const loadContent = async () => {\r\n            try {\r\n                let raw = window.localStorage.getItem(\"projects\"); \r\n                if (raw == null) {\r\n                    try {\r\n                        const data =  await (await fetch(CONFIG.db)).json();\r\n                      \r\n                        window.localStorage.setItem(\"projects\",JSON.stringify(data.posts));\r\n                        setDesc(data.posts[Number(id)]);\r\n                    } catch (error) {\r\n                        console.error(error);\r\n                    }\r\n                }else {\r\n                    setDesc(JSON.parse(raw)[Number(id)])\r\n                }\r\n                console.log(desc);\r\n                \r\n            } catch (error) {\r\n                console.error(error);\r\n            }\r\n        \r\n            try {\r\n                let markdown = await Markdown(project);\r\n                setContent(markdown.data);\r\n            } catch (error) {\r\n                setContent(\"<div class=\\\"no-readme\\\"><h1>404 - Theres no content to display</h1><div>\");\r\n                console.error(error);\r\n                \r\n            }\r\n            setIsLoading(false);\r\n\r\n        }\r\n        loadContent();\r\n        \r\n    },[]);\r\n    if (!isLoading){\r\n        return  <div id=\"project\" style={getStyle()}>\r\n                        <div className=\"markdown-content markdown-body\" dangerouslySetInnerHTML = {{__html: content}}></div>\r\n                </div>\r\n    }\r\n    return <div className=\"loader\">\r\n            <Spin size=\"54px\" name=\"cube-grid\" color=\"#ff3e00\" />\r\n        </div>\r\n\r\n} ","C:\\webprojects\\website2\\src\\access\\github.ts",[],["70","71"],"C:\\webprojects\\website2\\src\\pages\\ViewProfile.tsx",[],"C:\\webprojects\\website2\\src\\access\\check_content.ts",["72"],{"ruleId":"73","replacedBy":"74"},{"ruleId":"75","replacedBy":"76"},{"ruleId":"77","severity":1,"message":"78","line":82,"column":3,"nodeType":"79","endLine":82,"endColumn":20,"suggestions":"80"},{"ruleId":"81","severity":1,"message":"82","line":93,"column":13,"nodeType":"83","endLine":93,"endColumn":16},{"ruleId":"81","severity":1,"message":"82","line":94,"column":13,"nodeType":"83","endLine":94,"endColumn":16},{"ruleId":"81","severity":1,"message":"82","line":95,"column":13,"nodeType":"83","endLine":95,"endColumn":16},{"ruleId":"81","severity":1,"message":"82","line":101,"column":13,"nodeType":"83","endLine":101,"endColumn":38},{"ruleId":"81","severity":1,"message":"82","line":102,"column":176,"nodeType":"83","endLine":102,"endColumn":179},{"ruleId":"81","severity":1,"message":"82","line":104,"column":73,"nodeType":"83","endLine":104,"endColumn":76},{"ruleId":"81","severity":1,"message":"82","line":116,"column":58,"nodeType":"83","endLine":116,"endColumn":87},{"ruleId":"77","severity":1,"message":"84","line":183,"column":3,"nodeType":"79","endLine":183,"endColumn":11,"suggestions":"85"},{"ruleId":"77","severity":1,"message":"86","line":147,"column":5,"nodeType":"79","endLine":147,"endColumn":7,"suggestions":"87"},{"ruleId":"77","severity":1,"message":"88","line":44,"column":7,"nodeType":"79","endLine":44,"endColumn":9,"suggestions":"89"},{"ruleId":"77","severity":1,"message":"90","line":64,"column":7,"nodeType":"79","endLine":64,"endColumn":9,"suggestions":"91"},{"ruleId":"73","replacedBy":"92"},{"ruleId":"75","replacedBy":"93"},{"ruleId":"94","severity":1,"message":"95","line":23,"column":33,"nodeType":"96","messageId":"9